# Toloseo - served behind Cloudflare Tunnel
# Caddy listens on :8080 (TLS handled by Cloudflare)
# Tunnel public hostname → http://localhost:8080
:8080 {
    encode zstd gzip

    handle /api/* {
        reverse_proxy localhost:3001 {
            # Give Hono ~95s to respond so Caddy surfaces upstream timeouts
            # before Cloudflare's fixed 100s cutoff triggers an opaque 524.
            transport http {
                dial_timeout 5s
                response_header_timeout 95s
                read_timeout 95s
            }
        }
    }

    handle {
        root * /opt/toloseo/web/dist
        file_server
        try_files {path} /index.html
    }

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    header /assets/* Cache-Control "public, max-age=31536000, immutable"
}
